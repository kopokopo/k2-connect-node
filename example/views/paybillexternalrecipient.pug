extends layout

block content

    br

    p !{message}
    .container
        .title.h3 Add Paybill External Recipient
        br
        form(action="/externalrecipient/paybill", method="post") 
            .form-group.row
                label.col-sm-2.col-form-label Paybill Name
                .col-sm-7
                    input.form-control(name="paybill_name", type='text', placeholder='Enter Paybill Name' required)
                    small.form-text.text-muted
                        | Enter Paybill Name       
            .form-group.row
                label.col-sm-2.col-form-label Paybill Number
                .col-sm-7
                    input.form-control(name="paybill_number", type='text', placeholder='Enter Paybill Number' required)
                    small.form-text.text-muted
                        | Enter Paybill Number
            .form-group.row
                label.col-sm-2.col-form-label Paybill Account Number
                .col-sm-7
                    input.form-control(name="paybill_account_number", type='text', placeholder='Enter Paybill Account Number' required)
                    small.form-text.text-muted
                        | Enter Paybill Account Number
            .form-group.row
                label.col-sm-2.col-form-label Nickname
                .col-sm-7
                    input.form-control(name="nickname", type='text', placeholder='Enter Nickname' required)
                    small.form-text.text-muted
                        | Enter Nickname
            br
            .form-group.row
                .col-sm-7
                    button.btn.btn-success(type='submit') Add External Recipient